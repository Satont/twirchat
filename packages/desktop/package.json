{
  "name": "@twirchat/desktop",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "electrobun dev",
    "dev": "bun run --parallel hmr start",
    "hmr": "vite --config vite.main.config.ts --port 5173",
    "build:views": "vite build --config vite.main.config.ts && vite build --config vite.overlay.config.ts",
    "gen": "cd src/platforms/youtube && bunx @bufbuild/buf generate",
    "typecheck": "tsgo --noEmit",
    "test": "bun test tests/",
    "build:prod": "bun run build:views && electrobun build --env=canary"
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.11.0",
    "@connectrpc/connect": "2.1.1",
    "@connectrpc/connect-node": "2.1.1",
    "@twirchat/shared": "workspace:*",
    "@twurple/api": "8.0.3",
    "@twurple/auth": "8.0.3",
    "@twurple/chat": "8.0.3",
    "electrobun": "1.16.0",
    "reka-ui": "2.9.2",
    "vue": "3.5.30"
  },
  "devDependencies": {
    "@bufbuild/buf": "1.66.1",
    "@bufbuild/protoc-gen-es": "2.11.0",
    "@connectrpc/protoc-gen-connect-es": "1.7.0",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitejs/plugin-vue": "6.0.5",
    "vite": "8.0.1"
  }
}
